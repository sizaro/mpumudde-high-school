generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================
// USERS & AUTHENTICATION
// ==========================

model User {
  id String @id @default(cuid())

  email String @unique

  password String

  isActive Boolean @default(true)

  roles UserRole[]

  director Director?

  teacher Teacher?

  parent Parent?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ==========================
// ROLES & PERMISSIONS
// ==========================

model Role {
  id String @id @default(cuid())

  name String @unique

  description String?

  users UserRole[]

  permissions RolePermission[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Permission {
  id String @id @default(cuid())

  name String @unique

  description String?

  roles RolePermission[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ==========================
// USER ROLE CONNECTION
// ==========================

model UserRole {
  id String @id @default(cuid())

  userId String

  roleId String

  user User @relation(fields: [userId], references: [id])

  role Role @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}

// ==========================
// ROLE PERMISSION CONNECTION
// ==========================

model RolePermission {
  id String @id @default(cuid())

  roleId String

  permissionId String

  role Role @relation(fields: [roleId], references: [id])

  permission Permission @relation(fields: [permissionId], references: [id])

  createdAt DateTime @default(now())

  @@unique([roleId, permissionId])
}

// ==========================
// DIRECTOR
// ==========================

model Director {
  id String @id @default(cuid())

  firstName String

  lastName String

  phone String?

  userId String @unique

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ==========================
// TEACHERS
// ==========================

model Teacher {
  id String @id @default(cuid())

  firstName String

  lastName String

  phone String?

  userId String @unique

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ==========================
// PARENTS
// ==========================

model Parent {
  id String @id @default(cuid())

  firstName String

  lastName String

  phone String?

  relationship String?
  // Father
  // Mother
  // Guardian

  userId String @unique

  user User @relation(fields: [userId], references: [id])

  students StudentParent[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ==========================
// STUDENTS
// ==========================

model Student {
  id String @id @default(cuid())

  admissionNumber String @unique

  firstName String

  lastName String

  dateOfBirth DateTime?

  gender String?

  isActive Boolean @default(true)

  academicYearId String?

  termId String?

  classId String?

  studentCategoryId String?

  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])

  term Term? @relation(fields: [termId], references: [id])

  schoolClass SchoolClass? @relation(fields: [classId], references: [id])

  studentCategory StudentCategory? @relation(fields: [studentCategoryId], references: [id])

  parents StudentParent[]

  payments Payment[]

  termFees StudentTermFee[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ==========================
// STUDENT - PARENT RELATION
// ==========================

model StudentParent {
  id String @id @default(cuid())

  studentId String

  parentId String

  relationship String?
  // Father
  // Mother
  // Guardian

  student Student @relation(fields: [studentId], references: [id])

  parent Parent @relation(fields: [parentId], references: [id])

  createdAt DateTime @default(now())

  @@unique([studentId, parentId])
}

// ==========================
// ACADEMIC SETUP & FEES
// ==========================

model AcademicYear {
  id String @id @default(cuid())

  name String @unique

  isActive Boolean @default(true)

  terms Term[]

  financeStructures FinanceStructure[]

  students Student[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Term {
  id String @id @default(cuid())

  name String
  // e.g., "Term 1 2024", "Term 2 2024"

  academicYearId String

  feeAmount Int @default(0)
  // e.g., 1000000 for 1 million shillings

  startDate DateTime?

  endDate DateTime?

  isActive Boolean @default(true)

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  studentTermFees StudentTermFee[]

  financeStructures FinanceStructure[]

  students Student[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([academicYearId, name])
}

model SchoolClass {
  id String @id @default(cuid())

  name String @unique

  isActive Boolean @default(true)

  students Student[]

  financeStructures FinanceStructure[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model StudentCategory {
  id String @id @default(cuid())

  name String @unique

  isActive Boolean @default(true)

  students Student[]

  financeStructures FinanceStructure[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model FeeType {
  id String @id @default(cuid())

  name String @unique

  isActive Boolean @default(true)

  financeStructures FinanceStructure[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model FinanceStructure {
  id String @id @default(cuid())

  academicYearId String

  termId String

  classId String

  studentCategoryId String

  feeTypeId String

  expectedAmount Int

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  term Term @relation(fields: [termId], references: [id])

  schoolClass SchoolClass @relation(fields: [classId], references: [id])

  studentCategory StudentCategory @relation(fields: [studentCategoryId], references: [id])

  feeType FeeType @relation(fields: [feeTypeId], references: [id])

  payments Payment[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([academicYearId, termId, classId, studentCategoryId, feeTypeId])
}

model StudentTermFee {
  id String @id @default(cuid())

  studentId String

  termId String

  amountOwed Int

  amountPaid Int @default(0)

  student Student @relation(fields: [studentId], references: [id])

  term Term @relation(fields: [termId], references: [id])

  payments Payment[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([studentId, termId])
}

model Payment {
  id String @id @default(cuid())

  studentId String

  studentTermFeeId String?

  financeStructureId String?

  amount Int

  method String

  status String @default("completed")

  description String?

  date DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])

  studentTermFee StudentTermFee? @relation(fields: [studentTermFeeId], references: [id])

  financeStructure FinanceStructure? @relation(fields: [financeStructureId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
